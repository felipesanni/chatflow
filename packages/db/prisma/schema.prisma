generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  agent
}

enum UserStatus {
  active
  inactive
}

enum AgentPresence {
  online
  offline
  busy
}

enum TicketStatus {
  open
  pending
  closed
}

enum MessageDirection {
  inbound
  outbound
  system
}

enum MessageContentType {
  text
  image
  audio
  video
  document
  sticker
  other
}

enum AttachmentStorage {
  local
  s3
  minio
  external
}

enum InstanceStatus {
  disconnected
  pairing
  connected
  error
}

enum TicketEventType {
  created
  accepted
  assigned
  transferred
  queue_changed
  message_in
  message_out
  closed
  reopened
  tag_added
  tag_removed
}

model User {
  id          String      @id @db.Uuid
  email       String      @unique
  passwordHash String     @map("password_hash")
  role        UserRole    @default(agent)
  permissions Json        @default("{}")
  status      UserStatus  @default(active)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  lastLoginAt DateTime?   @map("last_login_at")
  agent       Agent?
  assignmentActions TicketAssignment[] @relation("assignment_created_by")
  ticketEvents TicketEvent[]

  @@map("users")
}

model Agent {
  id           String          @id @db.Uuid
  name         String
  avatarUrl    String?         @map("avatar_url")
  presence     AgentPresence   @default(offline)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  lastActiveAt DateTime?       @map("last_active_at")
  user         User            @relation(fields: [id], references: [id], onDelete: Cascade)
  tickets      Ticket[]        @relation("current_agent")
  messages     TicketMessage[]
  queueLinks   QueueAgent[]
  assignmentsFrom TicketAssignment[] @relation("assignment_from_agent")
  assignmentsTo   TicketAssignment[] @relation("assignment_to_agent")

  @@map("agents")
}

model Customer {
  id          String   @id @db.Uuid
  name        String
  phoneE164   String?  @unique @map("phone_e164")
  avatarUrl   String?  @map("avatar_url")
  email       String?
  companyName String?  @map("company_name")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tickets     Ticket[]

  @@map("customers")
}

model Queue {
  id          String   @id @db.Uuid
  name        String   @unique
  color       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tickets     Ticket[] @relation("current_queue")
  defaultForInstances WhatsAppInstance[] @relation("default_queue")
  queueAgents QueueAgent[]
  assignmentsFrom TicketAssignment[] @relation("assignment_from_queue")
  assignmentsTo   TicketAssignment[] @relation("assignment_to_queue")

  @@map("queues")
}

model QuickReply {
  id        String   @id @db.Uuid
  shortcut  String   @unique
  content   String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([shortcut])
  @@map("quick_replies")
}

model WhatsAppInstance {
  id                    String          @id @db.Uuid
  name                  String          @unique
  evolutionInstanceName String          @unique @map("evolution_instance_name")
  baseUrl               String          @map("base_url")
  apiKeyEncrypted       String          @map("api_key_encrypted")
  webhookSecret         String?         @map("webhook_secret")
  defaultQueueId        String?         @map("default_queue_id") @db.Uuid
  status                InstanceStatus  @default(disconnected)
  phoneNumber           String?         @map("phone_number")
  lastSeenAt            DateTime?       @map("last_seen_at")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  defaultQueue          Queue?          @relation("default_queue", fields: [defaultQueueId], references: [id], onDelete: SetNull)
  tickets               Ticket[]
  webhookLogs           WebhookLog[]

  @@map("whatsapp_instances")
}

model Ticket {
  id                   String           @id @db.Uuid
  customerId           String?          @map("customer_id") @db.Uuid
  whatsappInstanceId   String           @map("whatsapp_instance_id") @db.Uuid
  currentAgentId       String?          @map("current_agent_id") @db.Uuid
  currentQueueId       String?          @map("current_queue_id") @db.Uuid
  externalChatId       String           @map("external_chat_id")
  externalContactId    String?          @map("external_contact_id")
  customerNameSnapshot String           @map("customer_name_snapshot")
  customerAvatarUrl    String?          @map("customer_avatar_url")
  title                String?
  status               TicketStatus     @default(open)
  unreadCount          Int              @default(0) @map("unread_count")
  isGroup              Boolean          @default(false) @map("is_group")
  lastMessagePreview   String?          @map("last_message_preview")
  closedReason         String?          @map("closed_reason")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  closedAt             DateTime?        @map("closed_at")
  customer             Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  whatsappInstance     WhatsAppInstance @relation(fields: [whatsappInstanceId], references: [id])
  currentAgent         Agent?           @relation("current_agent", fields: [currentAgentId], references: [id], onDelete: SetNull)
  currentQueue         Queue?           @relation("current_queue", fields: [currentQueueId], references: [id], onDelete: SetNull)
  messages             TicketMessage[]
  assignments          TicketAssignment[]
  events               TicketEvent[]

  @@index([status, updatedAt(sort: Desc)])
  @@index([currentAgentId, updatedAt(sort: Desc)])
  @@index([currentQueueId, updatedAt(sort: Desc)])
  @@map("tickets")
}

model TicketMessage {
  id               String             @id @db.Uuid
  ticketId         String             @map("ticket_id") @db.Uuid
  senderAgentId    String?            @map("sender_agent_id") @db.Uuid
  externalMessageId String?           @map("external_message_id")
  direction        MessageDirection
  contentType      MessageContentType @default(text) @map("content_type")
  body             String?
  senderNameSnapshot String?          @map("sender_name_snapshot")
  rawPayload       Json?              @map("raw_payload")
  replyToMessageId String?            @map("reply_to_message_id") @db.Uuid
  deliveredAt      DateTime?          @map("delivered_at")
  readAt           DateTime?          @map("read_at")
  editedAt         DateTime?          @map("edited_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  ticket           Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderAgent      Agent?             @relation(fields: [senderAgentId], references: [id], onDelete: SetNull)
  replyToMessage   TicketMessage?     @relation("message_replies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies          TicketMessage[]    @relation("message_replies")
  attachments      Attachment[]

  @@index([ticketId, createdAt(sort: Asc)])
  @@index([externalMessageId])
  @@map("ticket_messages")
}

model Attachment {
  id            String            @id @db.Uuid
  messageId     String            @map("message_id") @db.Uuid
  fileName      String?           @map("file_name")
  mimeType      String            @map("mime_type")
  sizeBytes     BigInt?           @map("size_bytes")
  storage       AttachmentStorage
  storageKey    String            @map("storage_key")
  publicUrl     String?           @map("public_url")
  checksumSha256 String?          @map("checksum_sha256")
  createdAt     DateTime          @default(now()) @map("created_at")
  message       TicketMessage     @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("attachments")
}

model TicketAssignment {
  id              String    @id @db.Uuid
  ticketId        String    @map("ticket_id") @db.Uuid
  fromAgentId     String?   @map("from_agent_id") @db.Uuid
  toAgentId       String?   @map("to_agent_id") @db.Uuid
  fromQueueId     String?   @map("from_queue_id") @db.Uuid
  toQueueId       String?   @map("to_queue_id") @db.Uuid
  reason          String?
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  ticket          Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromAgent       Agent?    @relation("assignment_from_agent", fields: [fromAgentId], references: [id], onDelete: SetNull)
  toAgent         Agent?    @relation("assignment_to_agent", fields: [toAgentId], references: [id], onDelete: SetNull)
  fromQueue       Queue?    @relation("assignment_from_queue", fields: [fromQueueId], references: [id], onDelete: SetNull)
  toQueue         Queue?    @relation("assignment_to_queue", fields: [toQueueId], references: [id], onDelete: SetNull)
  createdByUser   User?     @relation("assignment_created_by", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt(sort: Desc)])
  @@map("ticket_assignments")
}

model TicketEvent {
  id          String          @id @db.Uuid
  ticketId    String          @map("ticket_id") @db.Uuid
  eventType   TicketEventType @map("event_type")
  actorUserId String?         @map("actor_user_id") @db.Uuid
  metadata    Json            @default("{}")
  createdAt   DateTime        @default(now()) @map("created_at")
  ticket      Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorUser   User?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt(sort: Desc)])
  @@map("ticket_events")
}

model WebhookLog {
  id                 String            @id @db.Uuid
  source             String
  eventName          String            @map("event_name")
  whatsappInstanceId String?           @map("whatsapp_instance_id") @db.Uuid
  payload            Json
  receivedAt         DateTime          @default(now()) @map("received_at")
  processedAt        DateTime?         @map("processed_at")
  statusCode         Int?              @map("status_code")
  errorMessage       String?           @map("error_message")
  whatsappInstance   WhatsAppInstance? @relation(fields: [whatsappInstanceId], references: [id], onDelete: SetNull)

  @@index([receivedAt(sort: Desc)])
  @@map("webhook_logs")
}

model QueueAgent {
  queueId    String   @map("queue_id") @db.Uuid
  agentId    String   @map("agent_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  queue      Queue    @relation(fields: [queueId], references: [id], onDelete: Cascade)
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@id([queueId, agentId])
  @@map("queue_agents")
}
